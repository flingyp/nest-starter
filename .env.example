# ==========================================
# 应用配置
# ==========================================
NODE_ENV=development
APP_PORT=8080
APP_PREFIX=api
APP_VERSION=1.0.0

# ==========================================
# 数据库配置 (Prisma + PostgreSQL)
# ==========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_starter?schema=public"

# ==========================================
# Redis 配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
